# SQL Server 2008
# Se MSSQL_PORT estiver preenchido, o script conecta em host:porta.
# Deixe MSSQL_PORT vazio para usar host\instancia.
# Em Windows legado, o driver instalado pode aparecer apenas como "SQL Server".
MSSQL_DRIVER=SQL Server
MSSQL_HOST=192.168.15.19
MSSQL_PORT=1433
MSSQL_INSTANCE=SQLEXPRESS
MSSQL_DATABASE=disque_denuncia
MSSQL_USER=sa
MSSQL_PASSWORD=@Senha123
MSSQL_ENCRYPT=no
MSSQL_TRUST_SERVER_CERTIFICATE=yes
MSSQL_TIMEOUT=30

# PostgreSQL Docker
PGHOST=localhost
PGPORT=5432
PGDATABASE=disque_denuncia_legado
PGUSER=postgres
PGPASSWORD=postgres
PGSCHEMA=public
PGCONNECT_TIMEOUT=10

# Aplicacao
BATCH_SIZE=1000
REJECT_LOG_PATH=migration_rejects.jsonl
